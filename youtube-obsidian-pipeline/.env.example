# Copy to .env, fill in real values, and reference it from the systemd
# service's EnvironmentFile= line (or `source .env` before running via cron).
#GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxx
SMTP_PASSWORD=

# Only needed for docker/docker-compose.yml (cloudflared webhook mode).
# Get this from the Cloudflare Zero Trust dashboard when creating a
# Docker-connector tunnel (Networks > Tunnels > Create a tunnel > Docker).
TUNNEL_TOKEN="op://Private/youtube-2-obsidian/cloudflare_auth"

# Only needed for docker/docker-compose.yml (the pipeline containers).
# No 1Password Service Account needed - these are the SAME op:// refs
# already used by config.yaml's github.token_op_ref /
# bridge.auth_token_op_ref / webhook.auth_token_op_ref. `op run
# --env-file` (see docker/docker-compose.yml's usage comment) resolves
# them on the host - already authenticated via the desktop app's CLI
# integration - before the containers ever start, and passes the
# resolved values through as plain env vars. Keep these in sync with
# config.yaml if you ever change those refs.
GITHUB_TOKEN="op://Private/youtube-2-obsidian/github fine grain"
BRIDGE_AUTH_TOKEN="op://Private/youtube-2-obsidian/bridge_auth_token"
WEBHOOK_AUTH_TOKEN="op://Private/youtube-2-obsidian/webhook_auth_token"

# Must exactly match config.yaml's github.subtitles_repo_path /
# github.vault_repo_path - bind-mounted into the containers at the same
# absolute path so config.yaml doesn't need container-specific overrides.
SUBTITLES_REPO_HOST_PATH=/Users/zim/git/youtube-subtitles
VAULT_REPO_HOST_PATH=/Users/zim/git/ai-test-sandbox-obsidian

# Runtime identity for the non-root pipeline containers. These default to
# 1000:1000; set them to the owner of state.json, token.json, pipeline.lock,
# and both bind-mounted repository directories.
PIPELINE_UID=1000
PIPELINE_GID=1000
